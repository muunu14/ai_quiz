generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-client"
}

datasource db {
  provider = "postgresql"
}

model User{
  id String@id @unique @default(uuid())
  isVerified Boolean @default (false)
  email String @unique
  createdAt DateTime @default(now())
  updatedate DateTime @updatedAt
}